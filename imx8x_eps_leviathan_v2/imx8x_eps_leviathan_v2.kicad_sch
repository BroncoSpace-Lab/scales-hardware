	)
	(text_box "This merger board seeks to combine the SCALES EPS board with the SCALES IMX8 Carrier Board. Both boards have undergone three revisions, this merger will combine the final revisions of both with each of them undergoing some more modifications based on seperate board reviews.\nNotable differences for each board compared to their individual counterparts are listed below.\n\nThis board is a revised version of the Leviathan 1 merger board.\nThis board contains:\n\nUART0 Over USBC\n28V 8A XT-60 Input\nI2C\nSPI\nGPIO\n2x1Gb Ethernet\nReset Button"
		(exclude_from_sim no)
		(at 13.208 22.86 0)
		(size 74.93 111.506)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
