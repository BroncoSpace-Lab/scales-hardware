				(size 1.27 1.27)
				(thickness 0.1588)
			)
			(justify left top)
		)
		(uuid "dba9ab9f-dff9-4301-a703-f2302cdab4fa")
	)
	(text_box "I2C Addresses Being Used on I2C0:\n\nINA260 OBC Subsystem: 0x41 \nINA260 Perif. Subsystem: 0x45\nINA260 Jetson Subsystem: 0x40\n\nMCP9808 OBC Subsystem: 0x19\nMCP9808 Perif. Subsystem: 0x1A\nMCP9808 Jet. Subsystem: 0x1B (0001 1011)\n"
		(exclude_from_sim no)
