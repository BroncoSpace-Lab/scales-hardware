	(text "Bootmode Toggler"
		(exclude_from_sim no)
		(at 66.04 62.23 0)
		(effects
			(font
				(size 1.905 1.905)
				(thickness 0.381)
				(bold yes)
			)
		)
		(uuid "c58a7014-33c5-49a7-ae9d-2ffc61a1d266")
	)
	(text_box "Description:\nThe SDCard/Wifi Mux(s) have been removed to allow for Default SDCard boot configuration and Utilization. If it is desired to use eMMC, then there must be a switch to toggle between boot modes, this is BOOTMODE[3:0] bits 0010 to eMMCand 0011 to SDcard respectively. Due to removal of all other boot configurations, we only need to switch the last bit using the provided switch we will include."
		(exclude_from_sim no)
		(at 12.7 12.7 0)
		(size 72.39 16.51)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "071fe4d5-6b28-485b-a52c-32c591b38577")
	)
	(text_box " SW1 Toggles Bootmode Bit 0,\n Bit 1 is always held high,\n and bits 2 and 3 are alwaysd\n held low. When SW1 is off,\n Bootmode0 is pulled up,\n defaulting to SD card. WHen\n SW1 is on, Bootmode 0 is\n pulled to GND, and eMMC is\n enabled."
		(exclude_from_sim no)
		(at 49.53 87.63 0)
		(size 33.02 19.05)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "727c0348-cf8d-4126-b900-6758e57194bd")
	)
